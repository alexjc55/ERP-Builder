# ============================================================================
#  Пример переменных окружения. Скопируйте в .env и заполните своими значениями:
#     cp .env.example .env
#  Файл .env в git НЕ попадает (см. .gitignore). Реальные секреты не коммитить!
# ============================================================================

# --- ОБЯЗАТЕЛЬНЫЕ ------------------------------------------------------------

# Строка подключения к PostgreSQL.
DATABASE_URL=postgresql://user:password@localhost:5432/erp

# Порт, на котором слушает API-сервер.
PORT=8080

# Секрет для подписи JWT и шифрования данных "at rest".
# Сгенерировать надёжное значение: openssl rand -hex 32
# ВАЖНО: если поменять на проде — все текущие сессии станут недействительны.
SESSION_SECRET=change-me-to-a-long-random-string

# Режим работы. На сервере всегда production.
NODE_ENV=production

# --- ХРАНИЛИЩЕ ФАЙЛОВ (лого, файловые поля с загрузкой "на сервер") ----------
# ВНИМАНИЕ: на Replit это Replit Object Storage (облачный бакет Google Cloud),
# он работает ТОЛЬКО внутри Replit. На своём сервере эти переменные сами по себе
# работать НЕ будут — нужна замена бэкенда хранилища (см. HELP.md, раздел
# "Файлы и хранилище"). Оставлены здесь для полноты.
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=
DEFAULT_OBJECT_STORAGE_BUCKET_ID=

# --- НЕОБЯЗАТЕЛЬНЫЕ ----------------------------------------------------------

# Модуль Google Drive (режим "свои ключи"). Нужны только если используете
# загрузку файлов в Google Drive. Без них модуль просто недоступен.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Уровень логирования: fatal | error | warn | info | debug | trace (по умолч. info)
LOG_LEVEL=info

# Только для Replit — список доменов приложения. На своём сервере не нужен.
# REPLIT_DOMAINS=
